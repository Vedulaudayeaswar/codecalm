FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/upload ./cmd/upload

FROM alpine:3.20
WORKDIR /app
COPY --from=build /out/upload /app/upload
RUN mkdir -p /app/submissions
ENV PORT=8081 SUBMISSIONS_DIR=/app/submissions
EXPOSE 8081
CMD ["/app/upload"]
