FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/metrics ./cmd/metrics

FROM alpine:3.20
WORKDIR /app
COPY --from=build /out/metrics /app/metrics
ENV KAFKA_BROKERS=kafka:9092 KAFKA_TOPIC=bot-events REDIS_ADDR=redis:6379
CMD ["/app/metrics"]
